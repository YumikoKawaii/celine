# Deployment env for docker-compose.yml (lives at ~/celine/.env on the host).
# Both interpolated into the compose (${...}) AND injected into containers (env_file).

# --- Image tag: which build to run (short commit SHA from CI) ---
IMAGE_TAG=sha-3cb15a9

# --- Database (the shared infra Postgres; celine schema) ---
DB_USER=celine
DB_PASSWORD=change-me
DB_NAME=celine

# --- Published ports on the host ---
SERVER_PORT=8080
EIDOS_PORT=5173

# --- App secrets (injected into server/worker containers) ---
# Auth is mandatory: CELINE_JWT_SECRET + both GOOGLE_* are required or the
# server refuses to start.
ANTHROPIC_API_KEY=sk-ant-...
BRAVE_API_KEY=
CELINE_JWT_SECRET=change-me-in-prod
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
